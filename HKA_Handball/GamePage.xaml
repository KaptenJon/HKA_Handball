<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:HKA_Handball.Controls"
             x:Class="HKA_Handball.GamePage"
             Title="HKA Handball"
             NavigationBarIsVisible="False"
             BackgroundColor="#2C1B0E">
    <Grid>
        <GraphicsView x:Name="GameView"
                      HorizontalOptions="FillAndExpand"
                      VerticalOptions="FillAndExpand">
            <GraphicsView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapped" />
            </GraphicsView.GestureRecognizers>
        </GraphicsView>

        <!-- Status bar top center -->
        <Label x:Name="StatusLabel" TextColor="#CCFFFFFF" FontSize="11" FontAttributes="Italic"
               HorizontalOptions="Center" VerticalOptions="Start" Margin="0,4,0,0" />

        <!-- LEFT THUMB: Joystick -->
        <controls:JoystickView x:Name="Joystick" WidthRequest="140" HeightRequest="140"
                               HorizontalOptions="Start" VerticalOptions="End" Margin="12,0,0,12" />

        <!-- RIGHT THUMB: Action buttons -->
        <Grid HorizontalOptions="End" VerticalOptions="End" Margin="0,0,12,12"
              RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,Auto"
              RowSpacing="6" ColumnSpacing="6">

            <!-- Attack controls (visible when attacking) -->
            <Button x:Name="PassUpButton" Text="⬆ Pass" FontSize="15"
                    BackgroundColor="#003DA5" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnPassUp" />
            <Button x:Name="PassDownButton" Grid.Row="1" Text="⬇ Pass" FontSize="15"
                    BackgroundColor="#003DA5" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnPassDown" />
            <Button x:Name="ShootButton" Grid.Row="2" Text="🎯 Skjut" FontSize="15"
                    BackgroundColor="#B71C1C" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnShoot" />

            <!-- Defense controls (visible when defending) -->
            <Button x:Name="SwitchDefenderButton" Grid.Row="2" Text="🔄 Byt" FontSize="15"
                    BackgroundColor="#FF8F00" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnSwitchDefender" />

            <!-- D-pad column (right of action buttons) -->
            <Grid x:Name="AttackDiagonalButtons" Grid.Column="1" Grid.RowSpan="3"
                  RowDefinitions="*,*,*" ColumnDefinitions="Auto" RowSpacing="4">
                <Button Text="↗" FontSize="22" BackgroundColor="#1B5E20" TextColor="White"
                        CornerRadius="10" HeightRequest="48" WidthRequest="52"
                        Pressed="OnAttackDiagUpPressed" Released="OnAttackDiagReleased" />
                <Button Grid.Row="1" Text="→" FontSize="22" BackgroundColor="#2E7D32" TextColor="White"
                        CornerRadius="10" HeightRequest="48" WidthRequest="52"
                        Pressed="OnAdvancePressed" Released="OnAdvanceReleased" />
                <Button Grid.Row="2" Text="↘" FontSize="22" BackgroundColor="#1B5E20" TextColor="White"
                        CornerRadius="10" HeightRequest="48" WidthRequest="52"
                        Pressed="OnAttackDiagDownPressed" Released="OnAttackDiagReleased" />
            </Grid>

            <Grid x:Name="DefenderSideButtons" Grid.Column="1" Grid.RowSpan="3"
                  RowDefinitions="*,*,*" ColumnDefinitions="Auto,Auto" RowSpacing="4" ColumnSpacing="4">
                <Button Text="↑" FontSize="22" BackgroundColor="#455A64" TextColor="White"
                        CornerRadius="10" HeightRequest="48" WidthRequest="52"
                        Pressed="OnDefenderSideUpPressed" Released="OnDefenderSideReleased" />
                <Button Grid.Row="1" Text="→" FontSize="22" BackgroundColor="#263238" TextColor="White"
                        CornerRadius="10" HeightRequest="48" WidthRequest="52"
                        Pressed="OnAdvancePressed" Released="OnAdvanceReleased" />
                <Button Grid.Row="2" Text="↓" FontSize="22" BackgroundColor="#455A64" TextColor="White"
                        CornerRadius="10" HeightRequest="48" WidthRequest="52"
                        Pressed="OnDefenderSideDownPressed" Released="OnDefenderSideReleased" />
                <Button Grid.Column="1" Text="↗" FontSize="22" BackgroundColor="#37474F" TextColor="White"
                        CornerRadius="10" HeightRequest="48" WidthRequest="52"
                        Pressed="OnDefenderDiagUpPressed" Released="OnDefenderDiagReleased" />
                <Button Grid.Column="1" Grid.Row="1" />
                <Button Grid.Column="1" Grid.Row="2" Text="↘" FontSize="22" BackgroundColor="#37474F" TextColor="White"
                        CornerRadius="10" HeightRequest="48" WidthRequest="52"
                        Pressed="OnDefenderDiagDownPressed" Released="OnDefenderDiagReleased" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
