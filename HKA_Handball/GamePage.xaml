<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:HKA_Handball.Controls"
             x:Class="HKA_Handball.GamePage"
             Title="HKA Handball"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#2C1B0E">
    <Grid>
        <GraphicsView x:Name="GameView"
                      HorizontalOptions="FillAndExpand"
                      VerticalOptions="FillAndExpand">
            <GraphicsView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapped" />
            </GraphicsView.GestureRecognizers>
        </GraphicsView>

        <!-- Status bar top center -->
        <Label x:Name="StatusLabel" TextColor="#CCFFFFFF" FontSize="11" FontAttributes="Italic"
               HorizontalOptions="Center" VerticalOptions="Start" Margin="0,4,0,0" />

        <!-- PLAYER 1 LEFT THUMB: Joystick -->
        <controls:JoystickView x:Name="Joystick" WidthRequest="140" HeightRequest="140"
                               HorizontalOptions="Start" VerticalOptions="End" Margin="12,0,0,12" />

        <!-- PLAYER 1 RIGHT THUMB: Action buttons (single-player and two-player, left side) -->
        <Grid x:Name="Player1Buttons" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,12,12"
              RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,Auto"
              RowSpacing="6" ColumnSpacing="6">

            <!-- Attack controls (visible when attacking) -->
            <Button x:Name="PassUpButton" Text="⬆ Pass" FontSize="15"
                    BackgroundColor="#003DA5" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnPassUp" />
            <Button x:Name="PassDownButton" Grid.Row="1" Text="⬇ Pass" FontSize="15"
                    BackgroundColor="#003DA5" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnPassDown" />
            <controls:GoalAimView x:Name="HomeGoalAim" Grid.Row="2"
                    HeightRequest="65" WidthRequest="100" />

            <!-- Defense controls (visible when defending) -->
            <Button x:Name="SwitchDefenderButton" Grid.Row="2" Text="🔄 Byt" FontSize="15"
                    BackgroundColor="#FF8F00" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnSwitchDefender" />
        </Grid>

        <!-- PLAYER 2 RIGHT THUMB: Joystick (two-player mode only) -->
        <controls:JoystickView x:Name="Joystick2" WidthRequest="140" HeightRequest="140"
                               HorizontalOptions="End" VerticalOptions="End" Margin="0,0,164,12"
                               IsVisible="False" />

        <!-- PLAYER 2 LEFT THUMB: Action buttons for away team (two-player mode only) -->
        <Grid x:Name="Player2Buttons" HorizontalOptions="Start" VerticalOptions="End" Margin="164,0,0,12"
              RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,Auto"
              RowSpacing="6" ColumnSpacing="6"
              IsVisible="False">

            <!-- Away attack controls -->
            <Button x:Name="AwayPassUpButton" Text="⬆ Pass" FontSize="15"
                    BackgroundColor="#B71C1C" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnAwayPassUp" />
            <Button x:Name="AwayPassDownButton" Grid.Row="1" Text="⬇ Pass" FontSize="15"
                    BackgroundColor="#B71C1C" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnAwayPassDown" />
            <controls:GoalAimView x:Name="AwayGoalAim" Grid.Row="2"
                    HeightRequest="65" WidthRequest="100" />

            <!-- Away defense controls -->
            <Button x:Name="AwaySwitchDefenderButton" Grid.Row="2" Text="🔄 Byt" FontSize="15"
                    BackgroundColor="#E65100" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnAwaySwitchDefender" />
        </Grid>
    </Grid>
</ContentPage>
