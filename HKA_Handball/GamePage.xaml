<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:HKA_Handball.Controls"
             x:Class="HKA_Handball.GamePage"
             Title="HKA Handball"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#2C1B0E">
    <Grid>
        <GraphicsView x:Name="GameView"
                      HorizontalOptions="FillAndExpand"
                      VerticalOptions="FillAndExpand">
            <GraphicsView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapped" />
            </GraphicsView.GestureRecognizers>
        </GraphicsView>

        <!-- Status bar top center -->
        <Label x:Name="StatusLabel" TextColor="#CCFFFFFF" FontSize="11" FontAttributes="Italic"
               HorizontalOptions="Center" VerticalOptions="Start" Margin="0,4,0,0" />

        <!-- LEFT THUMB: Joystick -->
        <controls:JoystickView x:Name="Joystick" WidthRequest="140" HeightRequest="140"
                               HorizontalOptions="Start" VerticalOptions="End" Margin="12,0,0,12" />

        <!-- RIGHT THUMB: Action buttons -->
        <Grid HorizontalOptions="End" VerticalOptions="End" Margin="0,0,12,12"
              RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,Auto"
              RowSpacing="6" ColumnSpacing="6">

            <!-- Attack controls (visible when attacking) -->
            <Button x:Name="PassUpButton" Text="⬆ Pass" FontSize="15"
                    BackgroundColor="#003DA5" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnPassUp" />
            <Button x:Name="PassDownButton" Grid.Row="1" Text="⬇ Pass" FontSize="15"
                    BackgroundColor="#003DA5" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnPassDown" />
            <Button x:Name="ShootButton" Grid.Row="2" Text="🎯 Skjut" FontSize="15"
                    BackgroundColor="#B71C1C" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnShoot" />

            <!-- Defense controls (visible when defending) -->
            <Button x:Name="SwitchDefenderButton" Grid.Row="2" Text="🔄 Byt" FontSize="15"
                    BackgroundColor="#FF8F00" TextColor="White" CornerRadius="12"
                    HeightRequest="52" MinimumWidthRequest="90"
                    Clicked="OnSwitchDefender" />

    
        </Grid>
    </Grid>
</ContentPage>
